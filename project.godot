; Pixel Platformer - Godot 4.7 C# 학습용 2D 플랫포머
; 방향키/WASD 이동, Space/W/Up 점프, R 재시작

config_version=5

[application]

config/name="Pixel Platformer"
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")

[dotnet]

project/assembly_name="platformer"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

environment/defaults/default_clear_color=Color(0.11, 0.13, 0.2, 1)
